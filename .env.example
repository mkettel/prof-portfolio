# Copy to .env and fill in real values.

# Resend API key — powers the contact form (src/app/api/contact/route.ts)
RESEND_API_KEY=

# Cal.com booking link in the form "username/event-type" (e.g. matt/consult).
# Until set to a real link, /book shows an email fallback instead of the embed.
NEXT_PUBLIC_CAL_LINK=
